{
    "name": "apteka999-backend",
    "version": "1.0.0",
    "description": "Сеть Аптек 999 — Backend API",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "node --watch server.js",
        "test": "jest --runInBand --forceExit",
        "test:watch": "jest --runInBand --watch"
    },
    "jest": {
        "testEnvironment": "node",
        "testMatch": [
            "**/tests/**/*.test.js"
        ],
        "testTimeout": 30000
    },
    "dependencies": {
        "axios": "^1.7.0",
        "bcryptjs": "^2.4.3",
        "compression": "^1.8.1",
        "cors": "^2.8.5",
        "dotenv": "^16.4.0",
        "express": "^4.21.0",
        "express-rate-limit": "^7.4.0",
        "helmet": "^8.0.0",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.8.0",
        "multer": "^1.4.5-lts.1",
        "node-cron": "^3.0.3",
        "xlsx": "^0.18.5"
    },
    "devDependencies": {
        "jest": "^30.4.2",
        "supertest": "^7.2.2"
    }
}
