# Apteka999 — Environment Variables
# Bu faylni .env ga nusxalang va qiymatlarni o'zgartiring

# Database
MONGODB_URI=mongodb://localhost:27017/apteka999

# JWT (32+ belgi, o'zgartiring!)
JWT_SECRET=CHANGE_ME_jwt_secret_32_characters
ADMIN_JWT_SECRET=CHANGE_ME_admin_jwt_secret_32chars

# Admin login
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2a$10$... # bcryptjs.hashSync('parolingiz', 10)

# Server
PORT=3000
FRONTEND_URL=https://your-miniapp-domain.com
ADMIN_URL=https://your-admin-domain.com

# Telegram
BOT_TOKEN=8609539425:AAFLQRqZU74y9RTVpmy9IymbF32Fo6d4vWQ
BOT_USERNAME=tridevyatka_bot
WEBAPP_URL=https://your-miniapp-domain.com
ADMIN_TELEGRAM_IDS=6078336227

# Click Payment
CLICK_SERVICE_ID=YOUR_CLICK_SERVICE_ID
CLICK_MERCHANT_ID=YOUR_CLICK_MERCHANT_ID
CLICK_SECRET_KEY=YOUR_CLICK_SECRET_KEY
CLICK_MERCHANT_USER_ID=YOUR_CLICK_MERCHANT_USER_ID

# Payme Payment
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
PAYME_TEST_MODE=true

# EFES Gateway — apteka999 orqali EFES loyihasiga webhook forwarding
# (test rejimda ikkala loyiha bitta Click/Payme merchant bilan ishlaydi)
EFES_BACKEND_URL=https://efes-app-production.up.railway.app

# Sync Agent (markaziy ofizdan keladigan stock sync uchun API kalit)
# Bu kalitni sync-agent/.env dagi SYNC_API_KEY bilan bir xil qiling
SYNC_API_KEY=CHANGE_ME_long_random_secret_64_chars

# Business Rules
MIN_ORDER_AMOUNT=50000
FREE_DELIVERY_THRESHOLD=150000
DELIVERY_COST=15000
BONUS_RATE=100
BONUS_PER_SUM=1
MAX_BONUS_PERCENT=30
ORDER_PAYMENT_TIMEOUT=30
WORKING_HOURS_START=9
WORKING_HOURS_END=22
