# Apteka999 Sync Agent — Filial konfiguratsiyasi
# Bu faylni .env ga nusxalang va o'z filialingiz uchun qiymatlarni to'ldiring

# ============================================================================
# 1. BACKEND (16 filial uchun BIR XIL)
# ============================================================================

# Backend manzili (oxirida / bo'lmasin)
BACKEND_URL=https://apteka999-production.up.railway.app

# Sync API kalit (hammada bir xil, backend .env bilan mos kelishi shart)
SYNC_API_KEY=BU_YERGA_BACKEND_BILAN_BIR_XIL_MAXFIY_KALIT

# ============================================================================
# 2. SHU FILIAL UCHUN UNIKAL
# ============================================================================

# Filial raqami — MongoDB Branch.number bilan mos kelishi shart
# Misol: Аптека №004 (Катартал) → BRANCH_NUMBER=4
BRANCH_NUMBER=1

# Lokal SQL Server manzili — odatda localhost (agent SQL Server kompyuteriga o'rnatilgan bo'lsa)
# Yoki tarmoqdagi boshqa kompyuter IP'si
MSSQL_HOST=localhost
MSSQL_PORT=1433

# RESIDUE jadvalidagi shu filialga tegishli OTDEL raqami.
# Topish uchun: SELECT OTDEL, SUM(OST) FROM RESIDUE WHERE GOOD=<biror_id> GROUP BY OTDEL
# va T_RESEDUE_V.KOL bilan mos kelganini tanlang. A2 uchun = 3.
# Bo'sh qolsa, partiyalar barcha filiallardan olinadi (noto'g'ri narx ko'rinishi mumkin).
MSSQL_OTDEL=

# ============================================================================
# 3. SQL Server login (16 filial uchun BIR XIL bo'lsa)
# ============================================================================

# ⚠️ XAVFSIZLIK:
# sa/1 ishlatish — full admin huquqi. Lokal kompyuterda ishlatish xavfsiz,
# ammo bu fayl GitHub yoki internetga ketmasligi shart!
MSSQL_USER=sa
MSSQL_PASSWORD=SQL_SERVER_PAROLI
MSSQL_DATABASE=NAPTSKLAD
MSSQL_TRUST_CERT=true
MSSQL_ENCRYPT=false

# ============================================================================
# 4. SYNC SOZLAMALARI (default qiymatlar OK)
# ============================================================================

# Necha daqiqada bir sinxronlash
SYNC_INTERVAL_MINUTES=5

# SQL so'rov timeout (sekund)
QUERY_TIMEOUT_SECONDS=60

# ============================================================================
# 5. OPERATOR DESKTOP OYNASI
# ============================================================================

OPERATOR_NAME=Kassa xodimi
ORDER_POLL_SECONDS=5

# Alohida operator kaliti bo'lsa kiriting; bo'sh bo'lsa SYNC_API_KEY ishlatiladi
OPERATOR_API_KEY=
